{
  "name": "getll",
  "displayName": "GetLL: NuGet Package Manager",
  "description": "Visual NuGet package management for VS Code workspaces.",
  "version": "0.1.0",
  "publisher": "piyushdoorwar",
  "license": "MIT",
  "icon": "media/getll.png",
  "author": {
    "name": "Piyush Doorwar"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/piyushdoorwar/getll.git"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "nuget",
    "dotnet",
    ".net",
    "csharp",
    "packages",
    "package manager"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onCommand:getll.openDashboard",
    "workspaceContains:**/*.csproj",
    "workspaceContains:**/*.fsproj",
    "workspaceContains:**/*.vbproj"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "getll",
          "title": "GetLL",
          "icon": "media/getll.svg"
        }
      ]
    },
    "views": {
      "getll": [
        {
          "id": "getll.home",
          "name": "GetLL",
          "type": "webview",
          "icon": "media/getll.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "getll.openDashboard",
        "title": "Open Dashboard",
        "category": "GetLL",
        "icon": "$(dashboard)"
      },
      {
        "command": "getll.refreshWorkspace",
        "title": "Refresh Workspace",
        "category": "GetLL",
        "icon": "$(refresh)"
      },
      {
        "command": "getll.searchPackages",
        "title": "Search Packages",
        "category": "GetLL",
        "icon": "$(search)"
      },
      {
        "command": "getll.addPackage",
        "title": "Add Package",
        "category": "GetLL",
        "icon": "$(add)"
      },
      {
        "command": "getll.removePackage",
        "title": "Remove Package",
        "category": "GetLL",
        "icon": "$(trash)"
      },
      {
        "command": "getll.updatePackage",
        "title": "Update Package",
        "category": "GetLL",
        "icon": "$(arrow-up)"
      },
      {
        "command": "getll.updateAllPackages",
        "title": "Update All Packages",
        "category": "GetLL"
      },
      {
        "command": "getll.showPackageDetails",
        "title": "View Package Details",
        "category": "GetLL",
        "icon": "$(info)"
      },
      {
        "command": "getll.restoreWorkspace",
        "title": "Restore Workspace",
        "category": "GetLL"
      },
      {
        "command": "getll.restoreSolution",
        "title": "Restore Solution",
        "category": "GetLL"
      },
      {
        "command": "getll.restoreProject",
        "title": "Restore Project",
        "category": "GetLL",
        "icon": "$(sync)"
      },
      {
        "command": "getll.manageSources",
        "title": "Manage Package Sources",
        "category": "GetLL"
      },
      {
        "command": "getll.addSource",
        "title": "Add Package Source",
        "category": "GetLL",
        "icon": "$(add)"
      },
      {
        "command": "getll.removeSource",
        "title": "Remove Package Source",
        "category": "GetLL",
        "icon": "$(trash)"
      },
      {
        "command": "getll.enableSource",
        "title": "Enable Package Source",
        "category": "GetLL"
      },
      {
        "command": "getll.disableSource",
        "title": "Disable Package Source",
        "category": "GetLL"
      },
      {
        "command": "getll.editSource",
        "title": "Edit Package Source",
        "category": "GetLL",
        "icon": "$(edit)"
      },
      {
        "command": "getll.openNugetConfig",
        "title": "Open NuGet.Config",
        "category": "GetLL"
      },
      {
        "command": "getll.checkOutdated",
        "title": "Check Outdated Packages",
        "category": "GetLL",
        "icon": "$(versions)"
      },
      {
        "command": "getll.checkVulnerable",
        "title": "Check Vulnerable Packages",
        "category": "GetLL",
        "icon": "$(shield)"
      },
      {
        "command": "getll.checkDeprecated",
        "title": "Check Deprecated Packages",
        "category": "GetLL"
      },
      {
        "command": "getll.openOutputChannel",
        "title": "Open Output Channel",
        "category": "GetLL"
      },
      {
        "command": "getll.openSettings",
        "title": "Open Settings",
        "category": "GetLL",
        "icon": "$(gear)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "getll.openDashboard",
          "when": "view == getll.home",
          "group": "navigation@1"
        }
      ]
    },
    "configuration": {
      "title": "GetLL",
      "properties": {
        "getll.defaultPackageSource": {
          "type": "string",
          "default": "",
          "description": "Name or URL of the package source used by default for installs and search. Empty uses nuget.org."
        },
        "getll.includePrerelease": {
          "type": "boolean",
          "default": false,
          "description": "Include prerelease versions in search results and version pickers by default."
        },
        "getll.autoRefreshOnProjectFileChange": {
          "type": "boolean",
          "default": true,
          "description": "Automatically refresh the package model when project or NuGet config files change."
        },
        "getll.scanOnStartup": {
          "type": "boolean",
          "default": true,
          "description": "Scan the workspace for .NET projects when the extension activates."
        },
        "getll.showTransitivePackages": {
          "type": "boolean",
          "default": false,
          "description": "Show transitive packages in the project tree when available."
        },
        "getll.enableCentralPackageManagementSupport": {
          "type": "boolean",
          "default": true,
          "description": "Enable support for Central Package Management (Directory.Packages.props)."
        },
        "getll.confirmBeforeMultiProjectChanges": {
          "type": "boolean",
          "default": true,
          "description": "Show a confirmation summary before applying changes to multiple projects."
        },
        "getll.restoreAfterInstall": {
          "type": "boolean",
          "default": false,
          "description": "Run dotnet restore after installing a package."
        },
        "getll.restoreAfterUpdate": {
          "type": "boolean",
          "default": false,
          "description": "Run dotnet restore after updating a package."
        },
        "getll.preferDotnetCli": {
          "type": "boolean",
          "default": false,
          "description": "Prefer the dotnet CLI for package search instead of the NuGet v3 HTTP API."
        },
        "getll.nugetOrgApiUrl": {
          "type": "string",
          "default": "https://api.nuget.org/v3/index.json",
          "description": "NuGet v3 service index URL used for nuget.org search and metadata."
        },
        "getll.maxSearchResults": {
          "type": "number",
          "default": 25,
          "minimum": 1,
          "maximum": 100,
          "description": "Maximum number of search results to fetch."
        },
        "getll.excludedFolders": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "bin",
            "obj",
            ".git",
            "node_modules",
            ".vs",
            ".vscode-test"
          ],
          "description": "Folder names excluded from workspace scanning."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "node esbuild.js && npm run webview:build",
    "watch": "node esbuild.js --watch",
    "package": "node esbuild.js --production && npm run webview:build",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "webview:dev": "npm --prefix webview-ui run dev",
    "webview:build": "npm --prefix webview-ui run build",
    "postinstall": "npm --prefix webview-ui install"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.96.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.24.0",
    "fast-xml-parser": "^4.5.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  }
}
